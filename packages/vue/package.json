{
  "name": "@vespera-ui/vue",
  "version": "0.10.0",
  "description": "Vespera design system — Vue 3 components.",
  "license": "Apache-2.0",
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsup",
    "typecheck": "tsc --noEmit"
  },
  "peerDependencies": {
    "vue": ">=3.3"
  },
  "devDependencies": {
    "vue": "^3.5.13"
  },
  "publishConfig": {
    "access": "public"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/forgialabs/vespera-ui.git",
    "directory": "packages/vue"
  },
  "keywords": [
    "vespera",
    "vue",
    "vue3",
    "design-system",
    "ui"
  ]
}
