---
// Full-page interactive playground for the Vespera design system.
// Uses the real @vespera-ui/react components, so every control actually works.
import '@vespera-ui/css';
import { Playground } from '../components/Playground';
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>Vespera · interactive playground</title>
    <link rel="icon" href="/vespera-ui/favicon.svg" type="image/svg+xml" />
    <style is:global>
      body {
        margin: 0;
      }
      .wrap {
        max-width: 1080px;
        margin: 0 auto;
        padding: 28px 22px 96px;
        position: relative;
        z-index: 1;
      }
      .demo-head {
        display: flex;
        align-items: center;
        gap: 14px;
        margin-bottom: 8px;
      }
      .demo-controls {
        display: flex;
        flex-wrap: wrap;
        gap: 8px;
        align-items: center;
        margin: 18px 0 26px;
      }
      .demo-controls .sep {
        width: 1px;
        height: 22px;
        background: var(--border);
        margin: 0 4px;
      }
      .swatch {
        width: 26px;
        height: 26px;
        border-radius: 50%;
        border: 2px solid var(--border-strong);
        cursor: pointer;
        padding: 0;
      }
      .swatch.on {
        border-color: #fff;
        box-shadow: 0 0 0 2px var(--accent);
      }
      .grid2 {
        display: grid;
        grid-template-columns: repeat(2, 1fr);
        gap: var(--gap);
      }
      @media (max-width: 760px) {
        .grid2 {
          grid-template-columns: 1fr;
        }
      }
      .row {
        display: flex;
        flex-wrap: wrap;
        gap: 10px;
        align-items: center;
      }
      .stack {
        display: flex;
        flex-direction: column;
        gap: 14px;
      }
    </style>
  </head>
  <body>
    <Playground client:load />
  </body>
</html>
