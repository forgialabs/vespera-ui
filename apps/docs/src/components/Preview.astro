---
// Live component preview. Two modes:
//  • demo="<name>"  → renders the named demo from the registry inside an isolated
//    <iframe> (embed/[demo].astro). Use for anything with overlays / portals /
//    fixed positioning (dropdowns, dialogs, tooltips, date pickers, the kanban
//    drag-ghost) so it stays *inside the frame* and portals resolve to the frame's
//    own `.vsp-root` instead of the first one on the page.
//  • default slot   → renders inline in a themed `.vsp-root` stage. Use for static,
//    non-overlay components.
import '@vespera-ui/css';
import { Code } from '@astrojs/starlight/components';

interface Props {
  code?: string;
  /** Registry key — when set, renders in an isolated iframe (see registry.ts). */
  demo?: string;
  theme?: 'dark' | 'light';
  center?: boolean;
}
const { code, demo, theme = 'dark', center = false } = Astro.props;
const base = import.meta.env.BASE_URL.replace(/\/$/, '');
---

{
  demo ? (
    <div class="vsp-pv">
      <iframe
        class="vsp-pv-frame"
        src={`${base}/embed/${demo}/`}
        title={`${demo} demo`}
        loading="lazy"
        scrolling="no"
      />
      {code && <Code code={code} lang="tsx" />}
    </div>
  ) : (
    <div class="vsp-pv">
      <div
        class:list={['vsp-root', 'vsp-pv-stage', { 'is-center': center }]}
        data-theme={theme}
        data-density="comfortable"
        data-corners="round"
      >
        <slot />
      </div>
      {code && <Code code={code} lang="tsx" />}
    </div>
  )
}

<script>
  // Auto-size each isolated demo iframe to its content (reported via postMessage).
  window.addEventListener('message', (e) => {
    const data = e.data as { vsp?: string; h?: number } | null;
    if (!data || data.vsp !== 'frame-h' || typeof data.h !== 'number') return;
    document.querySelectorAll<HTMLIFrameElement>('iframe.vsp-pv-frame').forEach((f) => {
      if (f.contentWindow === e.source) f.style.height = `${data.h}px`;
    });
  });
</script>

<style>
  .vsp-pv {
    margin: 1.25rem 0 1.75rem;
  }
  .vsp-pv-frame {
    display: block;
    width: 100%;
    height: 320px;
    border: 1px solid var(--sl-color-gray-5);
    border-bottom: 0;
    border-radius: 12px 12px 0 0;
    background: var(--sl-color-black);
    color-scheme: dark;
  }
  .vsp-pv-stage {
    border: 1px solid var(--sl-color-gray-5);
    border-bottom: 0;
    border-radius: 12px 12px 0 0;
    padding: 32px 28px;
    min-height: 0;
    display: flex;
    flex-wrap: wrap;
    gap: 12px;
    align-items: center;
  }
  .vsp-pv-stage.is-center {
    justify-content: center;
  }
  /* square off the code block under the stage */
  .vsp-pv :global(.expressive-code) {
    margin-top: 0;
  }
  .vsp-pv :global(.expressive-code .frame pre) {
    border-radius: 0 0 12px 12px;
  }
</style>
