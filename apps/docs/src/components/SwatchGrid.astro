---
// Themed stage that lays out <Swatch> chips in a responsive grid. Renders inside a
// .vsp-root so the tokens resolve to live values.
import '@vespera-ui/css';
interface Props {
  theme?: 'dark' | 'light';
  /** Min column width in px. */
  min?: number;
}
const { theme = 'dark', min = 150 } = Astro.props;
---

<div
  class="vsp-root sw-grid"
  data-theme={theme}
  data-density="comfortable"
  data-corners="round"
  style={`--sw-min:${min}px`}
>
  <slot />
</div>

<style>
  .sw-grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(var(--sw-min), 1fr));
    gap: 1rem;
    padding: 1.5rem;
    border: 1px solid var(--sl-color-gray-5);
    border-radius: 12px;
    margin: 1.25rem 0 1.75rem;
  }
</style>
