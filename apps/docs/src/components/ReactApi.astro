---
import manifest from '@manifest/react.json';
// Renders the prop tables for one category's components (each as an H2 so it gets
// its own anchor + TOC entry). Pass `category`; defaults to the whole package.
interface Props {
  category?: string;
}
const { category } = Astro.props;
const items = category
  ? manifest.components.filter((c) => c.category === category)
  : manifest.components;
---

<p>
  <strong>
    {items.length}{' '}
    {items.length === 1 ? 'component' : 'components'}
  </strong>
   in <code>{manifest.package}</code>. Generated from the TypeScript source — props marked{' '}
  <code>*</code> are required.
</p>

{
  items.map((c) => (
    <section>
      <h2 id={c.name}>{c.name}</h2>
      {c.description && <p>{c.description}</p>}
      {c.props.length > 0 ? (
        <table>
          <thead>
            <tr>
              <th>Prop</th>
              <th>Type</th>
              <th>Default</th>
            </tr>
          </thead>
          <tbody>
            {c.props.map((p) => (
              <tr>
                <td>
                  <code>
                    {p.name}
                    {p.required ? ' *' : ''}
                  </code>
                </td>
                <td>
                  <code>{p.values && p.values.length ? p.values.join(' | ') : (p.type ?? '—')}</code>
                </td>
                <td>{p.defaultValue ? <code>{p.defaultValue}</code> : '—'}</td>
              </tr>
            ))}
          </tbody>
        </table>
      ) : (
        <p>
          <em>No public props.</em>
        </p>
      )}
    </section>
  ))
}
